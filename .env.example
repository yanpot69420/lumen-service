# Salin file ini menjadi .env lalu isi dari Supabase Dashboard → Settings → API.
# Kunci "anon public" AMAN ditaruh di frontend — dilindungi oleh Row Level
# Security. JANGAN masukkan service_role key ke sini.
#
# Bila kedua nilai kosong, aplikasi berjalan mode LOKAL (IndexedDB) seperti biasa.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
